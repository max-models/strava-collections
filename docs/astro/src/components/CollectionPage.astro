---
import Layout from '../layouts/Layout.astro';

interface Props {
  title: string;
  bodyHtml: string;
}

const { title, bodyHtml } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<Layout title={title}>
  <nav class="mb-6 flex items-center gap-2 text-sm text-slate-500">
    <a href={base} class="hover:text-strava transition-colors">Collections</a>
    <span>/</span>
    <span class="text-slate-800 font-medium">{title}</span>
  </nav>

  <article class="collection-body" set:html={bodyHtml} />
</Layout>

<style is:global>
  .collection-body h1 {
    font-size: 2.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .collection-body h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #0f172a;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .collection-body p {
    color: #475569;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .collection-body iframe {
    border: none;
    border-radius: 12px;
  }

  .collection-body table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1.5rem;
    font-size: 0.875rem;
  }

  .collection-body th {
    background: #f1f5f9;
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    color: #334155;
    border-bottom: 2px solid #e2e8f0;
  }

  .collection-body td {
    padding: 10px 14px;
    border-bottom: 1px solid #e2e8f0;
    color: #475569;
  }

  .collection-body tr:last-child td {
    border-bottom: none;
  }

  .collection-body a {
    color: #fc4c02;
    text-decoration: none;
  }

  .collection-body a:hover {
    text-decoration: underline;
  }
</style>
