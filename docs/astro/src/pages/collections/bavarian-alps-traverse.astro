import CollectionPage from '../../components/CollectionPage.astro';

const title = "Bavarian alps traverse";
const bodyHtml = "<h1>Bavarian alps traverse</h1>\n<div style=\"position: relative; width: 100%; height: 350px;\">\n<iframe src=\"/strava-collections/_static/collection-bavarian-alps-traverse-map.html\" style=\"width:100%; height:100%; border:none;\"></iframe>\n</div>\n\n<div style=\"position: relative; width: 100%; height: 220px; aspect-ratio: 3 / 1;\">\n  <iframe src=\"/strava-collections/_static/collection-bavarian-alps-traverse-elev.html\" style=\"width:100%; height:100%; border:none; border-radius: 12px;\"></iframe>\n</div>\n\n<div class=\"description-box\">\n<div class=\"description-title\">Bad Reichenhall to Salzburg \ud83c\udfc3\u26f0\ufe0f</div>\n<div>\n2024-08-30 <img src=\"https://media.istockphoto.com/id/1442152045/vector/path-route-icon-distance-symbol.jpg?s=612x612&w=0&k=20&c=2ilIa1pWHJp550B31t__1NPc0CHpouutgdxt7QO4EJg=\" class=\"static-icon\">36 km <img src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS_EkMEkMAdgDcE0W6nELzmmMrqHToRcoS8eA&s\" class=\"static-icon\">1997 m <img src=\"https://cdn-icons-png.freepik.com/512/13063/13063145.png\" class=\"static-icon\"><span>7:17:30</span>\n        <a href=\"https://www.strava.com/activities/12284003055\" class=\"icon-link\" target=\"_blank\" rel=\"noopener\"><img src=\"https://cdn.worldvectorlogo.com/logos/strava-2.svg\" class=\"icon\"></a></div>\n\n<br>\n\n<div class=\"description-text\">Last piece of the eastward direction of the Bavarian alps traverse. So far the tour is 402km with 24118 hm. \n\nhttps://maxcodebox.github.io/biketours/bavarian-alp-traverse.html\n\n\u26f0\ufe0f Berchtesgadener Hochthron (1,972 m) \u2022 \u26f0\ufe0f Hochalpkopf (1,886 m) \u2022 \u26f0\ufe0f Gro\u00dfer Heubergkopf (1,820 m) \u2022 \u26f0\ufe0f Salzburger Hochthron (1,853 m) \u2022 \u26f0\ufe0f Geiereck (1,805 m) | \ud83c\udf10 summitbag.com</div>\n\n<div style=\"position: relative; width: 100%; height: 220px; aspect-ratio: 3 / 1;\">\n  <iframe src=\"/strava-collections/_static/activity-12284003055.html\" style=\"width:100%; height:100%; border:none; border-radius: 12px;\"></iframe>\n</div>\n\n<div class=\"gallery\"><a href=\"https://dgtzuqphqg23d.cloudfront.net/6ZjFy_nG0x5w_JfIRRlKIQyzImy75iN7u537b1Ohc0w-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-0\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/6ZjFy_nG0x5w_JfIRRlKIQyzImy75iN7u537b1Ohc0w-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Salzburg \ud83c\udfc3\u26f0\ufe0f photo 1\"></a><a href=\"https://image.mux.com/gXcW1a3tLb0202T6WKkVcWgAzm2QeluvcEEKppL55mGrU/thumbnail.jpg?width=640&height=360&fit_mode=preserve&time=0\" class=\"glightbox\" data-gallery=\"collection-gallery-0\"><img src=\"https://image.mux.com/gXcW1a3tLb0202T6WKkVcWgAzm2QeluvcEEKppL55mGrU/thumbnail.jpg?width=640&height=360&fit_mode=preserve&time=0\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Salzburg \ud83c\udfc3\u26f0\ufe0f photo 2\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/R9rBvkfRhEAd87Zvd9-OmiMQMOX6hhWvRDVM7VgWbpA-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-0\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/R9rBvkfRhEAd87Zvd9-OmiMQMOX6hhWvRDVM7VgWbpA-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Salzburg \ud83c\udfc3\u26f0\ufe0f photo 3\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/xMMD11zKS4cj9iXEgWhlW0E6g-s4OsNCnEjrX-nc9VM-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-0\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/xMMD11zKS4cj9iXEgWhlW0E6g-s4OsNCnEjrX-nc9VM-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Salzburg \ud83c\udfc3\u26f0\ufe0f photo 4\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/DK8HjbJ7sbCURk1_iwGmUv0hSmq-eGOjWZNmQKZ3W-g-768x410.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-0\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/DK8HjbJ7sbCURk1_iwGmUv0hSmq-eGOjWZNmQKZ3W-g-768x410.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Salzburg \ud83c\udfc3\u26f0\ufe0f photo 5\"></a></div></div>\n\n<div class=\"description-box\">\n<div class=\"description-title\">Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f</div>\n<div>\n2024-08-24 <img src=\"https://media.istockphoto.com/id/1442152045/vector/path-route-icon-distance-symbol.jpg?s=612x612&w=0&k=20&c=2ilIa1pWHJp550B31t__1NPc0CHpouutgdxt7QO4EJg=\" class=\"static-icon\">36 km <img src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS_EkMEkMAdgDcE0W6nELzmmMrqHToRcoS8eA&s\" class=\"static-icon\">2463 m <img src=\"https://cdn-icons-png.freepik.com/512/13063/13063145.png\" class=\"static-icon\"><span>9:19:24</span>\n        <a href=\"https://www.strava.com/activities/12231765525\" class=\"icon-link\" target=\"_blank\" rel=\"noopener\"><img src=\"https://cdn.worldvectorlogo.com/logos/strava-2.svg\" class=\"icon\"></a></div>\n\n<br>\n\n<div class=\"description-text\">Second to last part to Salzburg! Lots of climbing along the ridge, beautiful but almost no shaded areas.\n\n\u26f0\ufe0f Fuderheustein (1,321 m) \u2022 \u26f0\ufe0f Hochstaufen (1,771 m) \u2022 \u26f0\ufe0f Mittelstaufen (1,657 m) \u2022 \u26f0\ufe0f Hendelbergskopf (1,613 m) \u2022 \u26f0\ufe0f Zennokopf (1,756 m) \u2022 \u26f0\ufe0f Zwiesel (1,782 m) \u2022 \u26f0\ufe0f Gamsknogel (1,750 m) \u2022 \u26f0\ufe0f Zellerberg Hauptgipfel (1,065 m) \u2022 \u26f0\ufe0f Zellerberg Nordgipfel (992 m) | \ud83c\udf10 summitbag.com</div>\n\n<div style=\"position: relative; width: 100%; height: 220px; aspect-ratio: 3 / 1;\">\n  <iframe src=\"/strava-collections/_static/activity-12231765525.html\" style=\"width:100%; height:100%; border:none; border-radius: 12px;\"></iframe>\n</div>\n\n<div class=\"gallery\"><a href=\"https://image.mux.com/4XfZRRzkxshFCXDXoioeKXI2e01ONGK7Gk6tsDVqU02hU/thumbnail.jpg?width=640&height=360&fit_mode=preserve&time=0\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://image.mux.com/4XfZRRzkxshFCXDXoioeKXI2e01ONGK7Gk6tsDVqU02hU/thumbnail.jpg?width=640&height=360&fit_mode=preserve&time=0\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 1\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/Rkl3U8OofFOShdvKwvVFefvTwkJD7AU3YKmrhMt1vhA-768x369.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/Rkl3U8OofFOShdvKwvVFefvTwkJD7AU3YKmrhMt1vhA-768x369.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 2\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/g_q5oFbgDNv_kq0_oV9HqY9KMuteKDbARU_5cQ0ydzE-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/g_q5oFbgDNv_kq0_oV9HqY9KMuteKDbARU_5cQ0ydzE-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 3\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/4MNDM4aI-7Vig0UCF7VBzGy85Jazym4jdoyGQAhbqVU-593x768.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/4MNDM4aI-7Vig0UCF7VBzGy85Jazym4jdoyGQAhbqVU-593x768.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 4\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/mhaDxzli5w8A3aHkLp_N8uerXLsgxIkkRg-f6cJ78pw-768x384.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/mhaDxzli5w8A3aHkLp_N8uerXLsgxIkkRg-f6cJ78pw-768x384.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 5\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/gFS4INlx3zoTIMnNlh_2MYevyr-qhNCe83LntN25pOA-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/gFS4INlx3zoTIMnNlh_2MYevyr-qhNCe83LntN25pOA-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 6\"></a><a href=\"https://image.mux.com/ERCzauZDMOUt4nbbahfBM01tg1oiRVMK1KOlVNEupEfs/thumbnail.jpg?width=360&height=640&fit_mode=preserve&time=0\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://image.mux.com/ERCzauZDMOUt4nbbahfBM01tg1oiRVMK1KOlVNEupEfs/thumbnail.jpg?width=360&height=640&fit_mode=preserve&time=0\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 7\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/AhmvY0kWYZCoYMryXcDLeePFoL2PU-MhxdfAmEzn8h4-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/AhmvY0kWYZCoYMryXcDLeePFoL2PU-MhxdfAmEzn8h4-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 8\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/QqePkOHOGttyZGAPPM3OoMUUgLHdxWMH5U-bByynDUY-576x768.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/QqePkOHOGttyZGAPPM3OoMUUgLHdxWMH5U-bByynDUY-576x768.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 9\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/z4zNwVPZrTbimO8LWCYKus8Ym28crET8Ef9lo-2UfvA-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/z4zNwVPZrTbimO8LWCYKus8Ym28crET8Ef9lo-2UfvA-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 10\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/jbV5v9FJQ-I0Q2JZ4yuug_GCaXOjH0ylGhdXlOb5h3E-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/jbV5v9FJQ-I0Q2JZ4yuug_GCaXOjH0ylGhdXlOb5h3E-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 11\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/RVBPVEr42qRAnNfVsnb6eTbLZejFAXYFJNbmGyqG7Q0-768x485.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-1\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/RVBPVEr42qRAnNfVsnb6eTbLZejFAXYFJNbmGyqG7Q0-768x485.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Bad Reichenhall to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 12\"></a></div></div>\n\n<div class=\"description-box\">\n<div class=\"description-title\">Prien am Chiemsee to Ruhpolding \ud83c\udfc3\u26f0\ufe0f</div>\n<div>\n2024-06-08 <img src=\"https://media.istockphoto.com/id/1442152045/vector/path-route-icon-distance-symbol.jpg?s=612x612&w=0&k=20&c=2ilIa1pWHJp550B31t__1NPc0CHpouutgdxt7QO4EJg=\" class=\"static-icon\">51 km <img src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS_EkMEkMAdgDcE0W6nELzmmMrqHToRcoS8eA&s\" class=\"static-icon\">2723 m <img src=\"https://cdn-icons-png.freepik.com/512/13063/13063145.png\" class=\"static-icon\"><span>8:30:40</span>\n        <a href=\"https://www.strava.com/activities/11603714471\" class=\"icon-link\" target=\"_blank\" rel=\"noopener\"><img src=\"https://cdn.worldvectorlogo.com/logos/strava-2.svg\" class=\"icon\"></a></div>\n\n<br>\n\n<div class=\"description-text\">Last long run before CDH. Really warm day but still managed to stay strong. No snow anymore and large parts were very runnable! Tried out my megacap and it\u2019s amazing!\n\n\u26f0\ufe0f Ro\u00dfkopf (1,156 m) \u2022 \u26f0\ufe0f Hochgern (1,748 m) \u2022 \u26f0\ufe0f Thoraukopf (1,481 m) \u2022 \u26f0\ufe0f Hochfelln (1,674 m) | \ud83c\udf10 summitbag.com</div>\n\n<div style=\"position: relative; width: 100%; height: 220px; aspect-ratio: 3 / 1;\">\n  <iframe src=\"/strava-collections/_static/activity-11603714471.html\" style=\"width:100%; height:100%; border:none; border-radius: 12px;\"></iframe>\n</div>\n\n<div class=\"gallery\"><a href=\"https://dgtzuqphqg23d.cloudfront.net/WJ1Qp8w7xgBxkhBc9cwN5gwGp4HqqwC7MVvJVIWqyY0-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-2\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/WJ1Qp8w7xgBxkhBc9cwN5gwGp4HqqwC7MVvJVIWqyY0-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Prien am Chiemsee to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 1\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/z8-kpTuwb3-AKITn_UHaVY0wxFIZvi1yjZxm0AVOn8E-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-2\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/z8-kpTuwb3-AKITn_UHaVY0wxFIZvi1yjZxm0AVOn8E-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Prien am Chiemsee to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 2\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/IFw6F0pp90VUOEPm3I-7v3kqxKtsFz7w4Vx1rf7YMqM-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-2\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/IFw6F0pp90VUOEPm3I-7v3kqxKtsFz7w4Vx1rf7YMqM-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Prien am Chiemsee to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 3\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/ntJEFoKkQuZykvVgD9YiRIdpFH3xLXXDm9MsMBwn6tU-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-2\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/ntJEFoKkQuZykvVgD9YiRIdpFH3xLXXDm9MsMBwn6tU-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Prien am Chiemsee to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 4\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/xe80tR0R0Euf7apCZSckk-rk85yQlujRXFbcYK3Go5g-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-2\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/xe80tR0R0Euf7apCZSckk-rk85yQlujRXFbcYK3Go5g-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Prien am Chiemsee to Ruhpolding \ud83c\udfc3\u26f0\ufe0f photo 5\"></a></div></div>\n\n<div class=\"description-box\">\n<div class=\"description-title\">Aschau to Brannenburg \ud83c\udfc3\u26f0\ufe0f</div>\n<div>\n2024-05-24 <img src=\"https://media.istockphoto.com/id/1442152045/vector/path-route-icon-distance-symbol.jpg?s=612x612&w=0&k=20&c=2ilIa1pWHJp550B31t__1NPc0CHpouutgdxt7QO4EJg=\" class=\"static-icon\">28 km <img src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS_EkMEkMAdgDcE0W6nELzmmMrqHToRcoS8eA&s\" class=\"static-icon\">1429 m <img src=\"https://cdn-icons-png.freepik.com/512/13063/13063145.png\" class=\"static-icon\"><span>4:47:40</span>\n        <a href=\"https://www.strava.com/activities/11487681160\" class=\"icon-link\" target=\"_blank\" rel=\"noopener\"><img src=\"https://cdn.worldvectorlogo.com/logos/strava-2.svg\" class=\"icon\"></a></div>\n\n<br>\n\n<div class=\"description-text\">First some rain and mud and slippery climbs but it got better by the end. The plan was to continue to Bayerischzell but I cut it short to be sure I wouldn\u2019t miss the last train back.\n\n\u26f0\ufe0f Hammerstein (1,278 m) \u2022 \u26f0\ufe0f Zellerhorn (1,360 m) \u2022 \u26f0\ufe0f Jagerwand (1,396 m) \u2022 \u26f0\ufe0f Zellerwand (1,415 m) \u2022 \u26f0\ufe0f Hochries (1,569 m) \u2022 \u26f0\ufe0f Karkopf (1,496 m) \u2022 \u26f0\ufe0f P\u00f6lcher Schneid (1,390 m) | \ud83c\udf10 summitbag.com</div>\n\n<div style=\"position: relative; width: 100%; height: 220px; aspect-ratio: 3 / 1;\">\n  <iframe src=\"/strava-collections/_static/activity-11487681160.html\" style=\"width:100%; height:100%; border:none; border-radius: 12px;\"></iframe>\n</div>\n\n<div class=\"gallery\"><a href=\"https://dgtzuqphqg23d.cloudfront.net/21dzndL2JeZRFB9DeU93jFMcZeSU4LgH05QOZcua03g-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-3\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/21dzndL2JeZRFB9DeU93jFMcZeSU4LgH05QOZcua03g-768x576.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Aschau to Brannenburg \ud83c\udfc3\u26f0\ufe0f photo 1\"></a><a href=\"https://image.mux.com/52fMXKmden1mYcodmqnZzMwBiZqa5DzorQOHpPn02EQs/thumbnail.jpg?width=360&height=640&fit_mode=preserve&time=0\" class=\"glightbox\" data-gallery=\"collection-gallery-3\"><img src=\"https://image.mux.com/52fMXKmden1mYcodmqnZzMwBiZqa5DzorQOHpPn02EQs/thumbnail.jpg?width=360&height=640&fit_mode=preserve&time=0\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Aschau to Brannenburg \ud83c\udfc3\u26f0\ufe0f photo 2\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/dep-FCf_ILRTSHJBHHaH8VS9h_YaXV5q2fZy0DkQXlI-576x768.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-3\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/dep-FCf_ILRTSHJBHHaH8VS9h_YaXV5q2fZy0DkQXlI-576x768.jpg\" height=\"200\" class=\"lightbox-trigger\" loading=\"lazy\" decoding=\"async\" alt=\"Aschau to Brannenburg \ud83c\udfc3\u26f0\ufe0f photo 3\"></a><a href=\"https://dgtzuqphqg23d.cloudfront.net/L5B9XAB2C6Ua0hp0SeFkVpIx_siL1IsJAl6oue_O_4I-768x576.jpg\" class=\"glightbox\" data-gallery=\"collection-gallery-3\"><img src=\"https://dgtzuqphqg23d.cloudfront.net/L5B9XAB2C6Ua0hp0SeFkVpIx_siL1IsJAl6oue_O_4I-768x576.jpg\" height=\"200\" cla