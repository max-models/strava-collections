---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CollectionCard from '../components/CollectionCard.astro';

const allCollections = await getCollection('collections');

// Sort alphabetically by title
const sorted = allCollections.sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<Layout title="Home">
  <div class="mb-10 text-center">
    <h1 class="mb-2 text-4xl font-bold tracking-tight text-slate-900">
      Max's Runs &amp; Rides
    </h1>
    <p class="text-lg text-slate-500">
      A personal archive of multi-day adventures tracked on Strava.
    </p>
  </div>

  {sorted.length === 0 ? (
    <div class="rounded-2xl border border-dashed border-slate-300 bg-white px-8 py-20 text-center text-slate-400">
      <p class="text-lg font-medium">No collections yet.</p>
      <p class="mt-1 text-sm">
        Collections are generated by the Python pipeline and copied here during CI.
      </p>
    </div>
  ) : (
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {sorted.map((entry) => {
        const fileSlug = entry.slug; // "collection-bavarian-alps-traverse"
        const slug = fileSlug.replace(/^collection-/, '');
        return (
          <CollectionCard
            title={entry.data.title}
            slug={slug}
            fileSlug={fileSlug}
          />
        );
      })}
    </div>
  )}
</Layout>
