---
import CollectionPage from "../components/CollectionPage.astro";
import Map from "../components/Map.astro";
import { loadPlannedRouteData } from "../scripts/data-helpers";
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';
import yaml from 'js-yaml';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

function findLiveTrackingYaml(startDir: string): string {
  let curr = startDir;
  while (curr !== path.dirname(curr)) {
    const p = path.join(curr, 'live-tracking.yaml');
    if (fs.existsSync(p)) return p;
    curr = path.dirname(curr);
  }
  throw new Error('Could not find live-tracking.yaml in any parent directory');
}

const liveTrackingPath = findLiveTrackingYaml(__dirname);
const rootPath = path.dirname(liveTrackingPath);
const liveTrackingConfig = yaml.load(fs.readFileSync(liveTrackingPath, 'utf8')) as { collections: any[] };

const collection = liveTrackingConfig.collections[0];
const garminUrl = collection.activities.find((a: any) => a.garminLivetrackUrl)?.garminLivetrackUrl || collection.garminLivetrackUrl;
const customText = (collection as any).customText || "";

// Load planned route data statically
const plannedRouteData = loadPlannedRouteData(collection.routeGpxFile);

// Build-time fetch to avoid CORS issues
let livePoints: any[] = [];
let todayDist = 0;
try {
  const response = await fetch('https://bitter-silence-3781.max-lindqvist.workers.dev/history');
  if (response.ok) {
    const history = await response.json() as Array<{ key: string, data: { lat: number, lon: number, tst: number, alt?: number } }>;
    const sorted = history.sort((a, b) => a.data.tst - b.data.tst);
    let totalDist = 0;
    livePoints = sorted.map((entry, i) => {
      if (i > 0) {
        const p1 = sorted[i-1].data;
        const p2 = entry.data;
        const R = 6371000;
        const dLat = ((p2.lat - p1.lat) * Math.PI) / 180;
        const dLon = ((p2.lon - p1.lon) * Math.PI) / 180;
        const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) + Math.cos((p1.lat * Math.PI) / 180) * Math.cos((p2.lat * Math.PI) / 180) * Math.sin(dLon / 2) * Math.sin(dLon / 2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        totalDist += R * c;
      }
      return {
        lat: entry.data.lat,
        lon: entry.data.lon,
        elevation: entry.data.alt,
        distanceMeters: totalDist,
        time: new Date(entry.data.tst * 1000).toISOString()
      };
    }).filter(p => typeof p.lat === 'number' && typeof p.lon === 'number' && p.lat !== 0 && p.lon !== 0);

    // Calculate today's distance
    if (livePoints.length > 0) {
        const lastDate = new Date(livePoints.at(-1).time).toDateString();
        const pointsToday = livePoints.filter(p => new Date(p.time).toDateString() === lastDate);
        if (pointsToday.length > 1) {
            todayDist = pointsToday.at(-1).distanceMeters - pointsToday[0].distanceMeters;
        }
    }
  }
} catch (e) {
  console.error("Build-time fetch failed:", e);
}

const trackerPayload = {
  collections: [{
    name: collection.name,
    color: "#2563eb",
    plannedRouteData,
    activities: [{
      color: "#2563eb",
      routeData: livePoints.length > 0 ? {
        status: "ok",
        points: livePoints,
        summary: {
          pointCount: livePoints.length,
          isActive: true,
          lastReportedTime: livePoints.at(-1)?.time,
          totalDistanceMeters: livePoints.at(-1)?.distanceMeters
        }
      } : null,
      notes: "Live Progress",
      plannedRouteData: null
    }]
  }]
};

// Helper for elevation graph
const buildElevationSvg = (points: any[]) => {
  const data = points.filter(p => typeof p.elevation === 'number' && typeof p.distanceMeters === 'number');
  if (data.length < 2) return null;

  const width = 800;
  const height = 150;
  const padLeft = 40;
  const padRight = 20;
  const padTop = 10;
  const padBottom = 20;
  
  const xMin = 0;
  const xMax = data.at(-1).distanceMeters;
  const rawYMin = Math.min(...data.map(p => p.elevation));
  const rawYMax = Math.max(...data.map(p => p.elevation));
  const yMin = Math.floor(rawYMin / 10) * 10 - 10;
  const yMax = Math.ceil(rawYMax / 10) * 10 + 10;
  
  const scaleX = (x: number) => padLeft + (x / xMax) * (width - padLeft - padRight);
  const scaleY = (y: number) => height - padBottom - ((y - yMin) / (yMax - yMin)) * (height - padTop - padBottom);
  
  const path = data.map((p, i) => `${i === 0 ? 'M' : 'L'} ${scaleX(p.distanceMeters)} ${scaleY(p.elevation)}`).join(' ');
  const area = path + ` L ${scaleX(xMax)} ${height - padBottom} L ${scaleX(xMin)} ${height - padBottom} Z`;

  const tickCount = 4;
  const ticks = Array.from({ length: tickCount }, (_, i) => {
    const val = yMin + (i * (yMax - yMin)) / (tickCount - 1);
    return { val: Math.round(val), y: scaleY(val) };
  });

  return { path, area, width, height, yMin, yMax, xMax, ticks, padLeft, padRight, padBottom };
};

const elev = buildElevationSvg(livePoints);

const headings = [
  { title: "Live Map", slug: "live-map", level: 2 },
  { title: "Statistics", slug: "statistics", level: 2 },
  { title: "Elevation Profile", slug: "elevation-profile", level: 2 },
  ...(customText ? [{ title: "About the Ride", slug: "about", level: 2 }] : []),
  { title: "Data Sources", slug: "data-sources", level: 2 },
];

function formatDistance(m: number) {
    if (m >= 1000) return `${(m / 1000).toFixed(1)} km`;
    return `${Math.round(m)} m`;
}

function formatTime(iso: string) {
    if (!iso) return "-";
    return new Date(iso).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}
---

<CollectionPage title="Live Tracking" headings={headings}>
  <div class="mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <p class="text-slate-500 mt-1 text-base sm:text-lg">Follow the journey in real-time.</p>
    </div>
    <button 
      id="refresh-button"
      class="inline-flex items-center justify-center px-5 py-2.5 bg-strava border border-transparent rounded-xl text-sm font-bold text-white hover:opacity-90 transition-all shadow-lg active:scale-95"
    >
      <svg id="refresh-icon" class="mr-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
      Refresh Data
    </button>
  </div>

  <div class="space-y-12">
    <section id="live-map">
      <h2 class="sr-only">Live Map</h2>
      <Map payload={trackerPayload} />
    </section>

    <section id="statistics">
        <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-strava" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            Statistics
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm">
                <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Total Dist.</span>
                <strong class="text-2xl text-slate-900">{formatDistance(livePoints.at(-1)?.distanceMeters || 0)}</strong>
            </div>
            <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm">
                <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Today Dist.</span>
                <strong class="text-2xl text-strava">{formatDistance(todayDist)}</strong>
            </div>
            <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm">
                <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Last Point</span>
                <strong class="text-2xl text-slate-900">{formatTime(livePoints.at(-1)?.time)}</strong>
            </div>
            <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm">
                <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Track Points</span>
                <strong class="text-2xl text-slate-900">{livePoints.length}</strong>
            </div>
        </div>
    </section>

    {elev && (
      <section id="elevation-profile">
        <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-strava" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            Elevation Profile
        </h2>
        <div class="bg-white rounded-2xl p-6 shadow-md border border-slate-100">
          <div class="w-full">
            <svg viewBox={`0 0 ${elev.width} ${elev.height}`} class="w-full h-auto" preserveAspectRatio="none">
              <defs>
                <linearGradient id="elev-grad" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#fc4c02" stop-opacity="0.2" />
                  <stop offset="100%" stop-color="#fc4c02" stop-opacity="0" />
                </linearGradient>
              </defs>
              
              {elev.ticks.map(tick => (
                <g>
                  <line x1={elev.padLeft} y1={tick.y} x2={elev.width - elev.padRight} y2={tick.y} stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4 4" />
                  <text x={elev.padLeft - 8} y={tick.y} text-anchor="end" dominant-baseline="middle" fill="#94a3b8" font-weight="bold" style="font-size: 10px; font-family: ui-sans-serif, system-ui, sans-serif;">{tick.val}m</text>
                </g>
              ))}

              <path d={elev.area} fill="url(#elev-grad)" />
              <path d={elev.path} fill="none" stroke="#fc4c02" stroke-width="2" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="flex justify-between mt-2 pl-10 text-[10px] font-bold text-slate-400 uppercase">
            <span>Start</span>
            <span>{Math.round(elev.xMax / 1000)} km</span>
          </div>
        </div>
      </section>
    )}

    {customText && (
        <section id="about">
            <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                <svg class="w-5 h-5 text-strava" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                About the Ride
            </h2>
            <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 prose prose-slate max-w-none" set:html={customText}></div>
        </section>
    )}

    <section id="data-sources">
        <h2 class="text-xl font-bold text-slate-900 mb-6">Data Sources</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex items-center justify-between p-5 bg-slate-50 rounded-2xl border border-slate-200 shadow-sm">
                <div class="flex flex-col">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Live API</span>
                <code class="text-sm text-slate-600 mt-1 truncate max-w-[150px] sm:max-w-none">workers.dev/history</code>
                </div>
                <a href="https://bitter-silence-3781.max-lindqvist.workers.dev/history" target="_blank" rel="noopener noreferrer" class="p-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors shadow-sm" title="Raw API Feed">
                <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </a>
            </div>

            {garminUrl && (
                <div class="flex items-center justify-between p-5 bg-blue-50 rounded-2xl border border-blue-100 shadow-sm">
                <div class="flex flex-col">
                    <span class="text-xs font-bold text-blue-400 uppercase tracking-wider">Garmin LiveTrack</span>
                    <span class="text-sm text-blue-700 mt-1 font-medium">External Fallback</span>
                </div>
                <a href={garminUrl} target="_blank" rel="noopener noreferrer" class="p-2 bg-white border border-blue-200 rounded-lg hover:bg-blue-50 transition-colors shadow-sm" title="Open Garmin LiveTrack">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                </a>
                </div>
            )}
        </div>
    </section>
  </div>

  <script>
    const refreshBtn = document.getElementById('refresh-button');
    const refreshIcon = document.getElementById('refresh-icon');
    if (refreshBtn && refreshIcon) {
      refreshBtn.addEventListener('click', () => {
        refreshIcon.classList.add('animate-spin');
        window.location.reload();
      });
    }
  </script>
</CollectionPage>
