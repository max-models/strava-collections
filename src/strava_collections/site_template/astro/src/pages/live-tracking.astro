---
import Layout from "../layouts/Layout.astro";
import Map from "../components/Map.astro";
import "../styles/tracker.css";
import "leaflet/dist/leaflet.css";
import { loadGarminRouteData, loadPlannedRouteData } from "../scripts/data-helpers";
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';
import yaml from 'js-yaml';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

function findLiveTrackingYaml(startDir: string): string {
  let curr = startDir;
  while (curr !== path.dirname(curr)) {
    const p = path.join(curr, 'live-tracking.yaml');
    if (fs.existsSync(p)) return p;
    curr = path.dirname(curr);
  }
  throw new Error('Could not find live-tracking.yaml in any parent directory');
}

const liveTrackingPath = findLiveTrackingYaml(__dirname);
const rootPath = path.dirname(liveTrackingPath);
const liveTrackingConfig = yaml.load(fs.readFileSync(liveTrackingPath, 'utf8')) as { collections: any[] };

const collection = liveTrackingConfig.collections[0];
const garminActivity = collection.activities.find((a: any) => a.garminLivetrackUrl);
const garminUrl = garminActivity?.garminLivetrackUrl;
const routeData = garminUrl ? await loadGarminRouteData([garminActivity], {}) : null;

// Load planned route data from GPX files
const gpxFiles = collection.routeGpxFile || [];
const absoluteGpxPaths = (Array.isArray(gpxFiles) ? gpxFiles : [gpxFiles]).map(f => path.join(rootPath, f));
const plannedRouteData = loadPlannedRouteData(absoluteGpxPaths);

const trackerPayload = {
  collections: [
    {
      name: collection.name,
      plannedRouteData,
      activities: [
        {
          color: "#2563eb",
          garminLivetrackUrl: garminUrl,
          routeData: routeData?.[0] ?? null,
        }
      ]
    }
  ]
};
---

<Layout title="Live Tracking">
  <div class="page-shell">
    <header class="site-header">
      <h1>Live Tracking</h1>
    </header>

    <main>
      {garminUrl ? (
        <>
          <div class="map-shell">
            <Map payload={trackerPayload} className="map-canvas" autoInit={true} />
          </div>
          <div class="garmin-link">
            <a href={garminUrl} target="_blank" rel="noopener noreferrer">View on Garmin LiveTrack</a>
          </div>
        </>
      ) : (
        <div class="empty-state">
          No active live tracking found.
        </div>
      )}
    </main>
  </div>
</Layout>
