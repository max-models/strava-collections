---
import Layout from '../layouts/Layout.astro';
import CollectionCard from '../components/CollectionCard.astro';
import { collections } from '../generated/collections';
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';
import yaml from 'js-yaml';

const sorted = [...collections].sort((a, b) =>
  a.title.localeCompare(b.title)
);

// Check if live tracking is available
const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

function findLiveTrackingYaml(startDir: string): string | null {
  let curr = startDir;
  while (curr !== path.dirname(curr)) {
    const p = path.join(curr, 'live-tracking.yaml');
    if (fs.existsSync(p)) return p;
    curr = path.dirname(curr);
  }
  return null;
}

let hasLiveTracking = false;
const liveTrackingPath = findLiveTrackingYaml(__dirname);
if (liveTrackingPath) {
  try {
    const liveTrackingConfig = yaml.load(fs.readFileSync(liveTrackingPath, 'utf8')) as { collections: any[] };
    const collection = liveTrackingConfig.collections[0];
    hasLiveTracking = collection.activities?.some((a: any) => a.garminLivetrackUrl) || !!collection.garminLivetrackUrl;
  } catch (error) {
    console.error('Error reading live-tracking.yaml:', error);
  }
}
---

<Layout title="Home">
  <div class="mb-10 text-center">
    <h1 class="mb-2 text-4xl font-bold tracking-tight text-slate-900">
      Max's Runs &amp; Rides
    </h1>
    <p class="text-lg text-slate-500">
      A personal archive of multi-day adventures tracked on Strava.
    </p>
    {hasLiveTracking && (
      <div class="mt-4">
        <a
          href={`${import.meta.env.BASE_URL}live-tracking`}
          class="inline-flex items-center gap-2 px-6 py-3 bg-red-500 hover:bg-red-600 text-white font-semibold rounded-lg transition-colors shadow-md"
        >
          <span class="inline-block w-3 h-3 bg-white rounded-full animate-pulse"></span>
          Live Tracking
        </a>
      </div>
    )}
  </div>

  {sorted.length === 0 ? (
    <div class="rounded-2xl border border-dashed border-slate-300 bg-white px-8 py-20 text-center text-slate-400">
      <p class="text-lg font-medium">No collections yet.</p>
      <p class="mt-1 text-sm">
        Collections are generated by the Python pipeline and synced into Astro pages during CI.
      </p>
    </div>
  ) : (
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {sorted.map((entry) => {
        return (
          <CollectionCard
            title={entry.title}
            slug={entry.slug}
            fileSlug={entry.fileSlug}
          />
        );
      })}
    </div>
  )}
</Layout>
