---
interface Props {
  id: string;
  data: Array<{
    x: number[];
    y: number[];
    color: string;
    name: string;
  }>;
  height?: number;
}

const { id, data, height = 250 } = Astro.props;
---

<div id={id} class="elevation-chart" style={`height: ${height}px; width: 100%;`}></div>

<script is:inline define:vars={{ id, data, height }}>
  (function() {
    function getFillColor(color) {
      if (!color) return 'rgba(0,0,0,0.1)';
      if (color.startsWith('#')) {
        const r = parseInt(color.slice(1, 3), 16);
        const g = parseInt(color.slice(3, 5), 16);
        const b = parseInt(color.slice(5, 7), 16);
        return `rgba(${r}, ${g}, ${b}, 0.15)`;
      } else if (color.startsWith('rgb(')) {
        return color.replace('rgb(', 'rgba(').replace(')', ', 0.15)');
      }
      return color;
    }

    function renderChart() {
      const container = document.getElementById(id);
      if (!container || !window.Plotly) return;

      const traces = data.map(d => ({
        x: d.x,
        y: d.y,
        type: 'scatter',
        mode: 'lines',
        name: d.name,
        line: { color: d.color, width: 2.5 },
        fill: 'tozeroy',
        fillcolor: getFillColor(d.color),
        hovertemplate: '%{y:.0f}m at %{x:.1f}km<extra></extra>'
      }));

      const layout = {
        height: height,
        margin: { l: 45, r: 20, t: 10, b: 35 },
        showlegend: false,
        hovermode: 'x unified',
        xaxis: {
          title: { text: 'Distance (km)', font: { size: 11, color: '#64748b' } },
          showgrid: true,
          gridcolor: '#f1f5f9',
          zeroline: false,
          tickfont: { size: 10, color: '#94a3b8' }
        },
        yaxis: {
          title: { text: 'Elevation (m)', font: { size: 11, color: '#64748b' } },
          showgrid: true,
          gridcolor: '#f1f5f9',
          zeroline: false,
          tickfont: { size: 10, color: '#94a3b8' }
        },
        paper_bgcolor: 'rgba(0,0,0,0)',
        plot_bgcolor: 'rgba(0,0,0,0)',
        dragmode: false,
        xaxis: {
          title: { text: 'Distance (km)', font: { size: 11, color: '#64748b' } },
          showgrid: true,
          gridcolor: '#f1f5f9',
          zeroline: false,
          tickfont: { size: 10, color: '#94a3b8' },
          fixedrange: true
        },
        yaxis: {
          title: { text: 'Elevation (m)', font: { size: 11, color: '#64748b' } },
          showgrid: true,
          gridcolor: '#f1f5f9',
          zeroline: false,
          tickfont: { size: 10, color: '#94a3b8' },
          fixedrange: true
        }
      };

      const config = {
        responsive: true,
        displayModeBar: false,
        staticPlot: false,
        scrollZoom: false
      };

      window.Plotly.newPlot(id, traces, layout, config);
    }

    renderChart();
    document.addEventListener('astro:after-swap', renderChart);
  })();
</script>

<style>
  .elevation-chart {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
  }
</style>
