---
import CollectionPage from '../../components/CollectionPage.astro';
import Map from '../../components/Map.astro';
import ElevationChart from '../../components/ElevationChart.astro';
import {{ loadStravaRouteData, loadPlannedRouteData, loadPlannedRoutesIndividually }} from '../../scripts/data-helpers';

const title = {title_json};
const headings = {headings_json};
const metadata = {metadata_json};
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${{import.meta.env.BASE_URL}}/`;

// Prepare map data
const palette = ['#636EFA', '#EF553B', '#00CC96', '#AB63FA', '#FFA15A', '#19D3F3', '#FF6692', '#B6E880', '#FF97FF', '#FECB52'];
const stravaRouteData = loadStravaRouteData(metadata.activities || []);
const plannedRoutesIndividual = loadPlannedRoutesIndividually(metadata.routeGpxFile);
const trackerPayload = {{
  collections: [{{
    name: title,
    color: '#fc4c02',
    plannedRoutes: plannedRoutesIndividual,
    places: metadata.places || [],
    activities: (metadata.activities || []).map((act, i) => ({{
      ...act,
      color: palette[i % palette.length],
      routeData: stravaRouteData[i],
      plannedRouteData: loadPlannedRouteData(act.routeGpxFile),
    }}))
  }}]
}};
const fullscreenMapUrl = `{fullscreen_map_url}`;

// Prepare collection elevation data
let cumulativeDistance = 0;
const collectionElevationData = trackerPayload.collections[0].activities
  .filter(act => act.routeData?.status === "ok")
  .map(act => {{
    const points = [...act.routeData.points];
    const flip = act.strava_id?.[1] || act.flip || false;
    if (flip) {{
      points.reverse();
    }}
    
    const x = [];
    const y = [];
    
    let activityDistance = 0;
    for (let i = 0; i < points.length; i++) {{
      if (i > 0) {{
        const p1 = points[i-1];
        const p2 = points[i];
        const R = 6371; // km
        const dLat = (p2.lat - p1.lat) * Math.PI / 180;
        const dLon = (p2.lon - p1.lon) * Math.PI / 180;
        const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                  Math.cos(p1.lat * Math.PI / 180) * Math.cos(p2.lat * Math.PI / 180) *
                  Math.sin(dLon/2) * Math.sin(dLon/2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        activityDistance += R * c;
      }}
      x.push(cumulativeDistance + activityDistance);
      y.push(points[i].elevation || 0);
    }}
    const result = {{
      name: act.notes || "Activity",
      x,
      y,
      color: act.color
    }};
    cumulativeDistance += activityDistance;
    return result;
  }});
---

<CollectionPage title={{title}} headings={{headings}}>
  <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 break-words">{{title}}</h1>
  {{metadata.description && (
    <p class="text-lg text-slate-600 mb-8 leading-relaxed whitespace-pre-line break-words">{{metadata.description}}</p>
  )}}
  
  <section class="collection-stats-section mb-12 w-full overflow-hidden">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6 w-full">
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 p-4 md:p-6 rounded-2xl border border-blue-200 shadow-sm min-w-0">
        <span class="block text-xs font-bold text-blue-600 uppercase tracking-widest mb-2">Total Distance</span>
        <strong class="text-2xl md:text-3xl text-slate-900 break-words">{{metadata.totalDistanceKm}} km</strong>
      </div>
      <div class="bg-gradient-to-br from-green-50 to-green-100 p-4 md:p-6 rounded-2xl border border-green-200 shadow-sm min-w-0">
        <span class="block text-xs font-bold text-green-600 uppercase tracking-widest mb-2">Total Elevation Gain</span>
        <strong class="text-2xl md:text-3xl text-slate-900 break-words">{{metadata.totalElevationGainM}} m</strong>
      </div>
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 p-4 md:p-6 rounded-2xl border border-purple-200 shadow-sm min-w-0">
        <span class="block text-xs font-bold text-purple-600 uppercase tracking-widest mb-2">Total Moving Time</span>
        <strong class="text-2xl md:text-3xl text-slate-900 break-words">{{metadata.totalMovingTimeHours}} hrs</strong>
      </div>
    </div>
  </section>
  
  {{metadata.garminLivetrackUrl && (
    <section class="garmin-livetrack-section mb-12 w-full overflow-hidden" id="live-tracking">
      <h3 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
        <span class="inline-block w-3 h-3 bg-red-500 rounded-full animate-pulse"></span>
        Live Tracking
      </h3>
      You can change to km by clicking top right, then Statute and select Metric.
      <div class="garmin-iframe-container border-[3px] border-red-500 rounded-xl overflow-hidden mb-4 w-full max-w-full">
        <iframe
          src={{metadata.garminLivetrackUrl}}
          style="width: 100%; height: 800px; border: none;"
          title="Garmin LiveTrack Map"
        ></iframe>
      </div>
      <div class="flex flex-wrap items-center gap-4 mb-6">
        <a
          href={{metadata.garminLivetrackUrl}}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white hover:bg-gray-50 text-red-600 font-semibold rounded-lg border-2 border-red-500 transition-colors shadow-sm text-sm md:text-base max-w-full"
        >
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
          <span class="break-words">Open Full Garmin LiveTrack</span>
        </a>
      </div>
    </section>
  )}}
  <ElevationChart id="collection-elevation" data={{collectionElevationData}} height={{200}} />
  <Map payload={{trackerPayload}} fullscreenUrl={{fullscreenMapUrl}} />
  {markup}
</CollectionPage>

<script>
  import {{ setupMap }} from '../../scripts/map-renderer';

  function initActivityAssets() {{
    const mapContainers = document.querySelectorAll('.activity-map-canvas');
    const elevContainers = document.querySelectorAll('.activity-elevation-canvas');
    const dataEl = document.getElementById("map-data");
    if (!dataEl?.textContent) return;

    function getFillColor(color) {{
      if (!color) return 'rgba(0,0,0,0.1)';
      if (color.startsWith('#')) {{
        const r = parseInt(color.slice(1, 3), 16);
        const g = parseInt(color.slice(3, 5), 16);
        const b = parseInt(color.slice(5, 7), 16);
        return `rgba(${{r}}, ${{g}}, ${{b}}, 0.15)`;
      }} else if (color.startsWith('rgb(')) {{
        return color.replace('rgb(', 'rgba(').replace(')', ', 0.15)');
      }}
      return color;
    }}
    
    try {{
      const payload = JSON.parse(dataEl.textContent);
      const activities = payload.collections[0].activities;

      mapContainers.forEach(container => {{
        const activityId = container.getAttribute('data-activity-id');
        const activity = activities.find(a => {{
          const id = a.stravaActivityId || (a.strava_id ? String(a.strava_id[0]) : '');
          return id === activityId;
        }});
        
        if (activity && activity.routeData?.status === "ok" && container instanceof HTMLElement) {{
          setupMap({{
            containerId: container.id,
            tracks: [{{
              name: activity.notes || "Activity",
              points: activity.routeData.points,
              color: activity.color
            }}],
            plannedRoutes: activity.plannedRouteData ? [{{
              name: "Planned",
              points: activity.plannedRouteData.points,
              color: "#64748b",
              isPlanned: true
            }}] : []
          }});
        }}
      }});

      elevContainers.forEach(container => {{
        const activityId = container.getAttribute('data-activity-id');
        const activity = activities.find(a => {{
          const id = a.stravaActivityId || (a.strava_id ? String(a.strava_id[0]) : '');
          return id === activityId;
        }});

        if (activity && activity.routeData?.status === "ok" && container instanceof HTMLElement && window.Plotly) {{
          const points = [...activity.routeData.points];
          const flip = activity.strava_id?.[1] || activity.flip || false;
          if (flip) {{
            points.reverse();
          }}

          const x = [];
          const y = [];
          let dist = 0;
          for (let i = 0; i < points.length; i++) {{
            if (i > 0) {{
              const p1 = points[i-1], p2 = points[i];
              const R = 6371;
              const dLat = (p2.lat - p1.lat) * Math.PI / 180;
              const dLon = (p2.lon - p1.lon) * Math.PI / 180;
              const a = Math.sin(dLat/2)**2 + Math.cos(p1.lat * Math.PI/180) * Math.cos(p2.lat * Math.PI/180) * Math.sin(dLon/2)**2;
              dist += R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            }}
            x.push(dist);
            y.push(points[i].elevation || 0);
          }}

          const trace = {{
            x: x,
            y: y,
            type: 'scatter',
            mode: 'lines',
            fill: 'tozeroy',
            fillcolor: getFillColor(activity.color),
            line: {{ color: activity.color, width: 2.5 }},
            hovertemplate: '%{{y:.0f}}m at %{{x:.1f}}km<extra></extra>'
          }};

          window.Plotly.newPlot(container.id, [trace], {{
            height: 200,
            margin: {{ l: 45, r: 20, t: 10, b: 35 }},
            showlegend: false,
            dragmode: false,
            xaxis: {{ 
              title: {{ text: 'Distance (km)', font: {{ size: 11, color: '#64748b' }} }},
              showgrid: true,
              gridcolor: '#f1f5f9',
              zeroline: false,
              tickfont: {{ size: 10, color: '#94a3b8' }},
              fixedrange: true
            }},
            yaxis: {{ 
              title: {{ text: 'Elevation (m)', font: {{ size: 11, color: '#64748b' }} }},
              showgrid: true,
              gridcolor: '#f1f5f9',
              zeroline: false,
              tickfont: {{ size: 10, color: '#94a3b8' }},
              fixedrange: true
            }},
            paper_bgcolor: 'rgba(0,0,0,0)',
            plot_bgcolor: 'rgba(0,0,0,0)'
          }}, {{ responsive: true, displayModeBar: false, scrollZoom: false }});
        }}
      }});
    }} catch (e) {{
      console.error("Failed to initialize activity assets:", e);
    }}
  }}

  // Initialize on load
  initActivityAssets();

  // Re-initialize after Astro view transitions
  document.addEventListener('astro:after-swap', initActivityAssets);
</script>
